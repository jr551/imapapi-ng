# imapapi — mailcow addon configuration
# Copy to .env and adjust. Every line is optional — defaults are fine for a
# standard mailcow-dockerized install.

# HTTP listen port on the host (default: 3001).
# Set BIND_ADDR=127.0.0.1 if you're fronting this with nginx; use 0.0.0.0 only
# if you want to expose the port directly to the internet (combined with TLS).
PORT=3001
BIND_ADDR=0.0.0.0

# Mailcow Dovecot. Defaults work against mailcow-dockerized.
IMAP_HOST=dovecot-mailcow
IMAP_PORT=143
IMAP_SECURE=false
IMAP_TLS_REJECT_UNAUTHORIZED=true

# Docker network name. Set to whatever `docker network ls` shows for mailcow.
# Default matches mailcow-dockerized.
# MAILCOW_NETWORK=mailcowdockerized_mailcow-network

# Auth cache TTLs (ms). Keep valid TTL short so password rotations take effect.
CACHE_TTL_VALID_MS=60000
CACHE_TTL_INVALID_MS=10000

# Pool tuning.
POOL_MAX=50
POOL_IDLE_MS=30000

# pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info
