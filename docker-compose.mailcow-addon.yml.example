# Mailcow addon service for IMAP API
# This file provides a docker-compose service configuration to add IMAP API as a service to mailcow
#
# Installation:
# 1. Copy this file to your mailcow-dockerized directory as docker-compose.imapapi-addon.yml
# 2. Edit your mailcow.conf and add the following:
#    - IMAPAPI_DBHOST (defaults to redis-mailcow)
#    - IMAPAPI_DBPORT (defaults to 6379)
#    - IMAPAPI_DB (defaults to 8)
#    - IMAPAPI_HOST (defaults to 0.0.0.0)
#    - IMAPAPI_PORT (defaults to 3001)
# 3. Run docker compose up -d
#
# The IMAP API will be available at http://<mailcow-host>:3001
# It uses the same Redis instance as mailcow (redis-mailcow:6379)
#

services:
  imapapi-mailcow:
    image: imapapi:latest
    build:
      context: ./imapapi-addon
      dockerfile: Dockerfile
    hostname: imapapi-mailcow
    restart: always
    environment:
      - TZ=${TZ}
      - REDIS_URL=redis://${IMAPAPI_DBHOST:-redis-mailcow}:${IMAPAPI_DBPORT:-6379}/${IMAPAPI_DB:-8}
      - API_HOST=${IMAPAPI_HOST:-0.0.0.0}
      - API_PORT=${IMAPAPI_PORT:-3001}
      - LOG_LEVEL=${IMAPAPI_LOG_LEVEL:-info}
    ports:
      - "${IMAPAPI_PORT:-3001}:3000"
    depends_on:
      - redis-mailcow
    networks:
      mailcow-network:
        aliases:
          - imapapi-mailcow
    labels:
      - "com.centurylinklabs.watchtower.enable=false"
    volumes:
      - imapapi-logs:/var/log/imapapi
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:3000/metrics"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

volumes:
  imapapi-logs: