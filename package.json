{
    "name": "imapapi",
    "version": "1.2.14",
    "description": "Email Sync Engine",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "test": "grunt",
        "licenses": "npm-license-crawler --production --csv ./licenses.csv",
        "build": "pkg --out-path dist/ package.json --options max_old_space_size=4096"
    },
    "keywords": [
        "IMAP"
    ],
    "author": "Andris Reinman",
    "license": "AGPL-3.0-or-later",
    "bin": {
        "imapapi": "./bin/imapapi.js"
    },
    "dependencies": {
        "@hapi/boom": "9.1.4",
        "@hapi/hapi": "19.2.0",
        "@hapi/inert": "6.0.5",
        "@hapi/joi": "17.1.1",
        "@hapi/vision": "6.1.0",
        "@popperjs/core": "2.11.8",
        "bootstrap": "4.6.2",
        "bull": "3.29.3",
        "dotenv": "8.6.0",
        "email-reply-parser": "1.9.4",
        "exponential-backoff": "3.1.3",
        "hapi-pino": "8.5.0",
        "hapi-swagger": "13.1.0",
        "he": "1.2.0",
        "html-to-text": "5.1.1",
        "imapflow": "1.3.2",
        "ioredis": "4.31.0",
        "jquery": "3.7.1",
        "libmime": "4.2.1",
        "linkifyjs": "2.1.9",
        "momentjs": "2.0.0",
        "msgpack5": "4.5.1",
        "node-fetch": "2.7.0",
        "nodemailer": "^7.0.13",
        "pino": "6.14.0",
        "prom-client": "12.0.0",
        "qs": "6.15.1",
        "restify": "8.6.1",
        "wild-config": "1.7.1"
    },
    "devDependencies": {
        "eslint": "6.8.0",
        "eslint-config-nodemailer": "1.2.0",
        "eslint-config-prettier": "6.15.0",
        "grunt": "1.6.2",
        "grunt-cli": "1.5.0",
        "grunt-eslint": "22.0.0",
        "npm-license-crawler": "0.2.1",
        "pkg": "^4.5.1"
    },
    "pkg": {
        "scripts": "workers/**/*.js",
        "assets": [
            "views/**/*",
            "static/**/*"
        ]
    }
}
