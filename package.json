{
    "name": "imapapi",
    "version": "2.0.0",
    "private": true,
    "description": "Minimal stateless mailcow addon — REST access to IMAP using mailcow credentials",
    "main": "src/server.js",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "start": "node src/server.js",
        "dev": "node --watch src/server.js",
        "test": "node --test --test-concurrency=1 test/unit",
        "test:integration": "node --test --test-concurrency=1 --test-timeout=120000 test/integration",
        "test:all": "npm test && npm run test:integration"
    },
    "keywords": [
        "imap",
        "mailcow",
        "rest",
        "addon"
    ],
    "license": "AGPL-3.0-or-later",
    "author": "",
    "contributors": [
        "Andris Reinman (upstream imapapi author)"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/jr551/imapapi-ng.git"
    },
    "dependencies": {
        "@fastify/sensible": "6.0.4",
        "better-sqlite3": "12.9.0",
        "fastify": "5.8.5",
        "imapflow": "1.3.2",
        "pino": "10.3.1"
    },
    "devDependencies": {
        "pino-pretty": "13.1.3"
    }
}
